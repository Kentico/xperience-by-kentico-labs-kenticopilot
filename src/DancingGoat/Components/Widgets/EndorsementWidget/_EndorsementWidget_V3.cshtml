@using DancingGoat.Widgets
@model EndorsementWidgetViewModel

@if (string.IsNullOrEmpty(Model?.EndorsementQuote))
{
    if (Context.Kentico().PageBuilder().EditMode)
    {
        <div class="widget-configure-message">
            <p>Please select an endorsement to display.</p>
        </div>
    }
    return;
}

<div class="section-wrap">
    <div class="v3-endorsement">

        <!-- MAIN: Quote + Expert Identity -->
        <div class="v3-main">
            <div class="v3-eyebrow">Endorsed by an industry expert</div>

            <blockquote class="v3-quote">
                @Model.EndorsementQuote
            </blockquote>

            <div class="v3-expert-row">
                @if (Model.ShowExpertPhoto && !string.IsNullOrEmpty(Model.ExpertPhotoUrl))
                {
                    <img src="@Url.Content(Model.ExpertPhotoUrl)" alt="@Model.ExpertName" />
                }
                <div>
                    @if (!string.IsNullOrEmpty(Model.ExpertName))
                    {
                        <div class="v3-expert-name">@Model.ExpertName</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.ExpertTitle))
                    {
                        <div class="v3-expert-title">@Model.ExpertTitle</div>
                    }
                    @if (Model.ShowExpertBio && !string.IsNullOrEmpty(Model.ExpertBio))
                    {
                        <div class="v3-expert-bio">@Html.Raw(Model.ExpertBio)</div>
                    }
                </div>
            </div>

            <div class="v3-meta-row">
                @if (Model.ShowRating)
                {
                    <div class="star-rating">@(new string('★', Model.EndorsementRating))</div>
                }
                @if (Model.ShowDate)
                {
                    <div class="v3-date">@Model.EndorsementDate.ToString("MMMM yyyy")</div>
                }
                @if (Model.ShowExpertWebUrl && !string.IsNullOrEmpty(Model.ExpertWebUrl))
                {
                    <a href="@Model.ExpertWebUrl" target="_blank" rel="noopener" style="color:var(--c-link-gold);">@Model.ExpertWebUrl ↗</a>
                }
            </div>
        </div>

        <!-- SIDEBAR: Product -->
        <div class="v3-product-sidebar">
            <div class="v3-sidebar-label">Endorsed Product</div>
            @if (!string.IsNullOrEmpty(Model.ProductImageUrl))
            {
                <img src="@Url.Content(Model.ProductImageUrl)" alt="@Model.ProductName" />
            }
            @if (!string.IsNullOrEmpty(Model.ProductName))
            {
                <div class="v3-product-name">@Model.ProductName</div>
            }
            @if (Model.ShowProductDescription)
            {
                <div class="v3-product-desc">@Model.ProductDescription</div>
            }
            @if (!string.IsNullOrEmpty(Model.ProductPageUrl))
            {
                <a class="btn-cta" href="@Url.Content(Model.ProductPageUrl)">Shop Now</a>
            }
        </div>

    </div>
</div>
