@using DancingGoat.Widgets
@model EndorsementWidgetViewModel

@if (string.IsNullOrEmpty(Model?.EndorsementQuote))
{
    if (Context.Kentico().PageBuilder().EditMode)
    {
        <div class="widget-configure-message">
            <p>Please select an endorsement to display.</p>
        </div>
    }
    return;
}

<div class="section-wrap">
    <div class="v2-endorsement">

        <!-- LEFT: Product Panel -->
        <div class="v2-product-panel">
            @if (!string.IsNullOrEmpty(Model.ProductImageUrl))
            {
                <img src="@Url.Content(Model.ProductImageUrl)" alt="@Model.ProductName" />
            }
            @if (!string.IsNullOrEmpty(Model.ProductName))
            {
                <div class="v2-product-name">@Model.ProductName</div>
            }
            @if (Model.ShowProductDescription)
            {
                <div class="v2-product-desc">@Model.ProductDescription</div>
            }
            @if (!string.IsNullOrEmpty(Model.ProductPageUrl))
            {
                <a class="btn-cta" href="@Url.Content(Model.ProductPageUrl)">Shop Now</a>
            }
        </div>

        <!-- RIGHT: Endorsement Panel -->
        <div class="v2-endorsement-panel">
            <div class="v2-section-eyebrow">Expert Endorsement</div>

            <div>
                <div class="v2-quote-mark">&ldquo;</div>
                <div class="v2-quote">@Model.EndorsementQuote</div>
            </div>

            @if (Model.ShowRating)
            {
                <div class="v2-star-row">
                    <div class="star-rating">@(new string('★', Model.EndorsementRating))</div>
                    <div class="v2-star-label">@Model.EndorsementRating out of 5</div>
                </div>
            }

            <div class="v2-expert-badge">
                @if (Model.ShowExpertPhoto && !string.IsNullOrEmpty(Model.ExpertPhotoUrl))
                {
                    <img src="@Url.Content(Model.ExpertPhotoUrl)" alt="@Model.ExpertName" />
                }
                <div>
                    @if (!string.IsNullOrEmpty(Model.ExpertName))
                    {
                        <div class="v2-badge-name">@Model.ExpertName</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.ExpertTitle))
                    {
                        <div class="v2-badge-title">@Model.ExpertTitle</div>
                    }
                </div>
            </div>

            @if (Model.ShowDate)
            {
                <div class="v2-date">@Model.EndorsementDate.ToString("MMMM yyyy")</div>
            }
        </div>

    </div>
</div>
